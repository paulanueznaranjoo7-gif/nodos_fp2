class LinkedList:

    class Node:
        def __init__(self, value, next_node=None):
            self.value = value
            self.next_node = next_node

    def __init__(self):
        self.__first = None
        self.__len = 0

    def insert_first(self, value):
        self.__first = self.Node(value, self.__first)
        self.__len += 1

    def __iter__(self):
        current = self.__first
        while current is not None:
            yield current.value
            current = current.next_node
            
    def find_middle(self):
        fast = self.__first #utilizo dos punteros
        slow = self.__first #antes utilizaos prev = Nonem porwue el primero debia empezar en none
        while fast is not None and fast.next_node is not None:
            fast = fast.next_node.next_node #si queiro doble lo pongo dos veces
            slow = slow.next_node
        medio = slow.value
        return medio
            
            
if __name__ == "__main__":
    lista = LinkedList()

    valores = [10, 20, 30, 40, 50]

    for v in valores:
        lista.insert_first(v)

    print("Lista:", end=" ")
    for x in lista:
        print(x, end=" → ")

    print("\nMedio:", lista.find_middle())
