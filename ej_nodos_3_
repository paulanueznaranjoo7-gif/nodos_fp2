class LinkedList:

    class Node:
        def __init__(self, value, next_node=None):
            self.value = value
            self.next_node = next_node

    def __init__(self):
        self.__first = None

    def insert_first(self, value):
        self.__first = self.Node(value, self.__first)

    def __iter__(self):
        current = self.__first
        while current is not None:
            yield current.value
            current = current.next_node

    def eliminar_mayores(self, n):
        current = self.__first
        prev = None

        while current is not None:
            if current.value > n:
                if prev is None:
                # borrar primero
                    self.__first = current.next_node
                else:
                # borrar en medio
                    prev.next_node = current.next_node
            else:
                prev = current

            current = current.next_node


if __name__ == "__main__":
    lista = LinkedList()

    for v in [5, 10, 3, 8, 2, 7]:
        lista.insert_first(v)

    print("Original:", end=" ")
    for x in lista:
        print(x, end=" -> ")

    lista.eliminar_mayores(5)

    print("\nDespués (sin >5):", end=" ")
    for x in lista:
        print(x, end=" -> ")
