class LinkedList:
    def __init__(self):
        self.head = None

    class Node:
        def __init__(self, value, next_node=None):
            self.value = value
            self.next_node = next_node
        
    def append(self, value):
        new_node = self.Node(value)
        
        if self.head == None:
            self.head = new_node
        else:
            current = self.head
            
            while current.next_node is not None:
                current = current.next_node
                
            current.next_node = new_node
        
    def remove_value(self, value):
        current = self.head
        
        if self.head is not None and self.head.value == value: #lista no esta vacia, quiero borrar justo el primer nodo
            self.head = current.next_node
            return #paarq que si me lo encuentra pare
         
        while current.next_node is not None: #miro el siguiente nodo, por?, para cambiar un nodo he de cambar el enlace anterior
            if current.next_node.value == value:
                current.next_node = current.next_node.next_node #dos apunta al 6, me salto 5
            else:
                current = current.next_node #si el sieguiete nodo no lo quiero borrar, avanzo
    
    def reverse(self):
        anterior = None
        actual = self.head

        while actual is not None:
            siguiente = actual.next_node      # 1️⃣ guardar siguiente
            actual.next_node = anterior       # 2️⃣ invertir flecha
            anterior = actual                 # 3️⃣ avanzar anterior
            actual = siguiente               # 4️⃣ avanzar actual

        self.head = anterior                 # 🔥 nuevo head
            
            
    
                
        
            
