class LinkedList:

    class Node:
        def __init__(self, value, next_node=None):
            self.value = value
            self.next_node = next_node

    def __init__(self):
        self.__first = None

    def insert_first(self, value):
        self.__first = self.Node(value, self.__first)

    def __iter__(self):
        current = self.__first
        while current is not None:
            yield current.value
            current = current.next_node
            
    def sort_desc(self):
        sorted_list = None
        current = self.__first

        while current is not None:
            next_node = current.next_node

        # insertar en lista ordenada
            if sorted_list is None or current.value > sorted_list.value: #si la lista esta vacia, si current es mayor que el primer valor de la lista
                current.next_node = sorted_list
                sorted_list = current
            else:
                temp = sorted_list
                while temp.next_node is not None and temp.next_node.value > current.value:
                    temp = temp.next_node

                    current.next_node = temp.next_node
                    temp.next_node = current

            current = next_node

        self.__first = sorted_list
            
if __name__ == "__main__":
    lista = LinkedList()

    for v in [2, 5, 1, 3]:
        lista.insert_first(v)

    print("Antes:", end=" ")
    for x in lista:
        print(x, end=" → ")

    lista.sort_desc()

    print("\nDespués:", end=" ")
    for x in lista:
        print(x, end=" → ")
