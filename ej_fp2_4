class Playlist:
    class Node:
        def __init__(self, value, next=None):
            self.value = value
            self.next = next

# Escriba a partir de esta línea. No modifique esta línea ni las anteriores.
    def __init__(self):
        self.first = None
        self.last = None
    
    def add(self, value):
        new_node = Playlist.Node(value)
        
        if self.first is None:
            self.first = new_node
            self.last = new_node
        else:
            current = self.first
            while current.next is not None:
                current = current.next
            new_node.next = current.next
            current.next = new_node
            self.last = new_node
            
    def remove_repeated(self):
        current = self.first
        
        while self.first.next is not None and self.first.value == self.first.next.value:
            self.first = self.first.next
            
        current = self.first
        
        while current.next is not None:
            if current.value == current.next.value:
                current.next = current.next.next
            else:
                current = current.next


