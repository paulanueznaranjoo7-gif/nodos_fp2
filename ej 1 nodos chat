class LinkedList:

    class Node:
        def __init__(self, value, next_node=None):
            self.value = value
            self.next_node = next_node

    def __init__(self):
        self.__first = None
        self.__len = 0

    def insert_first(self, value):
        self.__first = self.Node(value, self.__first)
        self.__len += 1

    def __iter__(self):
        current = self.__first
        while current is not None:
            yield current.value
            current = current.next_node
    
    def sum_list(self):
        current = self.__first
        suma = 0
        while current is not None:
            suma += current.value #current es el nodo, debe ser value
            current = current.next_node
        return suma #usamos yield cuando quiero devolver variso valores, pcoo a pcoo 
            
        


if __name__ == "__main__":
    lista = LinkedList()

    valores = [10, 20, 30, 40]

    for v in valores:
        lista.insert_first(v)

    print("Lista:", end=" ")
    for x in lista:
        print(x, end=" → ")

    print("\nSuma:", lista.sum_list())
