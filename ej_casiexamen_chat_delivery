class Package:
    def __init__(self, code, weight):
        self.code = code
        self.weight = weight  # en kg

    def __str__(self):
        return f"{self.code} [{self.weight}kg]"
class Warehouse:
    class Node:
        def __init__(self, value, next=None):
            self.value = value  # objeto Package
            self.next = next

    def __init__(self):
        self.first = None
        self.last = None
    
    def push_front(self, package):
        new_node = self.Node(package)
        
        if self.first is None:
            self.first = new_node
            self.last = new_node
            return
        
        elif self.first is not None:
            new_node.next = self.first
            self.first = new_node
            
    def remove_last(self):
        
        if self.first is None:
            return None
        prev = self.first
        current = self.first.next
        
        if self.first == self.last: #solo hay un nodo
            current = None
            return 
        
        while current != self.last:
            prev = current
            current = current.next
        prev.next = None
        self.last = prev
    
    def find_heaviest(self):
